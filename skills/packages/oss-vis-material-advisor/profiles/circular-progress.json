{
    "name": "circular-progress",
    "title": "环形进度图",
    "category": "进度/加载",
    "version": "0.0.1",
    "author": "haoyingying",
    "scanned_at": "2026-06-17",
    "description": "单组数据的环形进度图，支持渐变、起点标识、外半径/环宽、起点位置、背景/前景色、填充透明度（仅1组数据）",
    "data_format": {
        "type": "row",
        "fields": [
            { "name": "id", "type": "String", "description": "指标ID" },
            { "name": "title", "type": "String", "description": "指标名称" },
            { "name": "percent", "type": "String", "required": true, "description": "指标值（百分比0-100）" },
            { "name": "unit", "type": "String", "description": "单位" }
        ],
        "row_count": "单组（仅一组数据）",
        "data_source": "DynamicData 多数据源",
        "_note": "description明确指明'仅支持一组数据'"
    },
    "visual_config": {
        "chartProps (图形)": {
            "isGradient": "Switch 渐变",
            "circular": "Switch 起点标识",
            "radius": "NumberPicker 外半径 [0,1] step=0.1",
            "ringWidth": "NumberPicker 圆环宽度 [0,1] step=0.1",
            "startPosition": "enum: top/bottom/left/right 起点位置",
            "padding": "NumberPicker 内边距",
            "backgroundColor": "ColorPicker 背景色",
            "foregroundColor": "ColorPicker 前景色",
            "fillOpacity": "SliderWithNumber 填充色透明度 [0,1]"
        },
        "digitalProps": "数字属性（百分比数字字号/颜色等）",
        "titleProps": "标题样式"
    },
    "interactions": {},
    "business_scenarios": [
        "单个指标完成率展示",
        "服务可用率/健康度",
        "单指标KPI进度"
    ],
    "composability": {
        "compatible_with": ["circular-progress-group", "ind-list-echarts-gauge", "digital-flop"],
        "replaces": ["ind-list-echarts-gauge（单指标）"],
        "extends": ["circular-progress-group（多组）"]
    },
    "rating": {
        "label": "🟡 组合可用",
        "score": 3.5,
        "breakdown": {
            "business_description": 3.5,
            "scenario_coverage": 3.0,
            "config_completeness": 4.0,
            "data_contract_clarity": 3.5,
            "doc_completeness": 2.5,
            "composability": 3.5
        }
    },
    "build_cost": {
        "complexity": "低",
        "setup_steps": [
            "准备单组数据（title + percent）",
            "配置 chartProps 图形参数（外半径/环宽/渐变/颜色）",
            "配置数字/标题样式"
        ],
        "dependencies": ["@fedx-vis 内部组件"],
        "estimated_minutes": 10
    },
    "_validation_notes": {
        "data_model_oss_material_json": "oss-material.json 的 dataModel 字段为空字符串",
        "data_type_issue": "percent 声明为 String，应为 Number",
        "doc_status": "无 doc/README.md",
        "single_data_only": "仅支持1组数据，多组用 circular-progress-group"
    }
}
