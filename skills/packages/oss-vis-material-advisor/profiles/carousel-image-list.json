            "composability": 4.5
        }
    },
    "build_cost": {
        "complexity": "低",
        "setup_steps": [
            "准备轮播数据（type + url + name + value）",
            "配置 swiperTimer 时间间隔",
            "配置元素布局（宽度/高度/flex）",
            "配置样式（选中边框/图片尺寸/边距）"
        ],
        "dependencies": ["图片资源"],
        "estimated_minutes": 12
    },
    "_validation_notes": {
        "data_model_oss_material_json": "oss-material.json 的 dataModel 字段为空字符串",
