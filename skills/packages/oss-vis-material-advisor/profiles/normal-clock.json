            "doc_completeness": 2.5,
            "composability": 4.0
        }
    },
    "build_cost": {
        "complexity": "极低",
        "setup_steps": [
            "选择 timeFormat 格式",
            "可选：启用整点传参（isTimeParams + timeParamsFormat + timeParamsDate）",
            "配置文本样式（颜色/字号/字体）"
        ],
        "dependencies": ["moment"],
        "estimated_minutes": 5
    },
    "_validation_notes": {
        "missing_data_model": "无 dataModel.json（无需数据）",
