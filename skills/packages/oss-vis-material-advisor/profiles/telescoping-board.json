      {
        "format": "树形列表式（id + parentId + label + value + unit + trend）",
        "example": "[{id:'1',parentId:'0',label:'主项1',value:'100',unit:'%',trend:'1'},{id:'1-1',parentId:'1',label:'子项1',value:'50',unit:'%',trend:'-1'},...]",
        "match_pattern": "data[0] 取 parentId='0' 第一个为主项；data[i].parentId==mainMenuIndicatorId 的为对比项（mainMenuTrendDatas）；展开菜单中 data[j].parentId==item.id 的为子项",
        "supports_multi_series": false,
        "fields": [
          { "name": "id", "type": "String", "required": true, "description": "唯一标识" },
          { "name": "parentId", "type": "String", "required": true, "description": "父级ID（'0' 表示主项，mainMenuIndicatorId 表示对比项，子项 ID 表示从属）" },
          { "name": "label", "type": "String", "required": true, "description": "名称" },
          { "name": "value", "type": "String(实际Number)", "required": true, "description": "数值" },
          { "name": "unit", "type": "String", "required": false, "description": "单位" },
          { "name": "trend", "type": "String", "required": false, "description": "趋势变化（'-1' 降 / '0' 平 / '1' 升）" }
        ],
        "match_logic": "mainMenuItem = dataSource.filter(parentId==='0').shift() → mainMenuIndicatorName/Value/Unit/Id；mainMenuTrendDatas = dataSource.filter(parentId===mainMenuIndicatorId)；menuItemDataSource = dataSource.filter(parentId==='0') - 1"
      }
    ],
    "interactions": [
