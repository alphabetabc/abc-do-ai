    "description": "数据大屏内嵌iframe组件，支持参数转码、模板字符串变量、点击下钻（Modal/Drawer）",
    "data_format": {
        "type": "row",
        "fields": "无dataModel（dimensions/indicators均空）",
        "data_source": "dataConfig（DynamicData）多数据源"
    },
    "visual_config": {
        "baseConfig (基础配置)": {
            "enableParamEncode": "Switch 参数转码（URL参数会被转码）",
