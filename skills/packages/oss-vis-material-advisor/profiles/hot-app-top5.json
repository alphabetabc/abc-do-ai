                "iconBgSize": { "type": "object", "default": "{width: 48, height: 66}" },
                "appIconPosition": { "type": "object", "default": "{left: 'center', top: 'bottom'}" },
                "topIndSettings": { "type": "array", "items": "{font, background}", "description": "Top1/2/3 单独设置（金/银/铜配色 + 编号 icon）" }
            },
            "appIndSettings.normal": {
                "width": { "type": "number", "default": 108 },
                "iconBgSize": { "type": "object", "default": "{width: 48, height: 48}" },
                "indSettings": { "type": "object", "description": "Top4/5 共用设置" }
            },
            "appIndSettings.appIcon": { "size": { "width": "number", "height": "number" } }
        },
        "default_values": {
            "config.title": "热门APPTOP5",
            "config.width": 432,
            "config.height": 300,
            "config.tabSettings.show": true,
            "config.tabSettings.width": 79,
