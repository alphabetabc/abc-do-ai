                "defaultActiveId": { "type": "string", "default": null },
                "width": { "type": "number", "default": 79 },
                "height": { "type": "number", "default": 32 },
                "spaceSize": { "type": "number", "default": 10 },
                "borderColor": { "normal": "string", "active": "string" },
