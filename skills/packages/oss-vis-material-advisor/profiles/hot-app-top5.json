            {
                "format": "双数据源（tab + topAppList）",
                "example": "{ tabDataSource: [{dictName:'视频', dictKey:'1'}, ...], appListDataSource: [{appName:'爱奇艺', appIcon:'', indicatorId:'1', indicatorName:'播放成功率', indicatorValue:'99.38', indicatorUnit:'%'}, ...] }",
                "match_pattern": "customDataSourceApiConfig.{tabDataSource, appListDataSource}[*]",
                "fields": [
                    { "name": "dictName", "type": "String", "required": true, "description": "Tab 显示名（视频/游戏/即时通信/支付）" },
                    { "name": "dictKey", "type": "String", "required": true, "description": "Tab ID，用于派发与下钻" },
                    { "name": "appName", "type": "String", "required": true, "description": "应用名（爱奇艺/腾讯视频/抖音/快手等）" },
                    { "name": "appIcon", "type": "String", "required": false, "description": "应用图标 URL" },
                    { "name": "indicatorId", "type": "String", "required": true, "description": "指标ID（如'1'=播放成功率,'2'=卡顿时长占比）" },
                    { "name": "indicatorName", "type": "String", "required": true, "description": "指标名" },
                    { "name": "indicatorValue", "type": "String(实际number)", "required": true, "description": "指标值" },
                    { "name": "indicatorUnit", "type": "String", "required": false, "description": "指标单位" }
                ]
            }
        ],
        "interactions": [
            {
                "type": "tab_change_dispatch",
                "trigger": "onTabChange (Tabs 切换)",
                "config_field": "interactions.action.actionDictName / actionDictKey",
                "behavior": "Tab 切换时把 dictName + dictKey 派发出去，同时 setState tabParams 触发 appListDataSource 重新请求"
            },
            {
                "type": "item_click_drilldown",
                "trigger": "onAppItemClick (AppList item 点击)",
                "config_field": "interactions.defined.configurableEvent.clickEvent",
                "sub_fields": ["show", "effect (Modal|Drawer)", "params", "drilldownItemFields", "position", "size", "mask", "closable", "title (Drawer)"],
                "payload": "整行 raw data"
            },
            {
                "type": "click_dispatch_appName",
                "trigger": "useInteractionHandle (clickEvent 派发)",
                "config_field": "interactions.defined.appName (在 appIndInteractions 单独定义)",
                "behavior": "点击 app 项时派发 appName"
            },
            {
                "type": "subscribe_zone_and_tab",
                "trigger": "useCustomDataSourceApi + useMemo",
                "config_field": "interactions.subscribe.{subscribeZoneLevel, subscribeZoneId, subscribeTabActiveId}",
                "behavior": "订阅 3 个外部参数（地区等级/地区Id/默认选中tabId），用于数据请求的 query 参数"
            },
            {
                "type": "tab_carousel",
                "trigger": "useRef + Tabs 内部 timer (mouseEnter/Leave 暂停/启动)",
                "config_field": "config.tabSettings.carousel.{enable, interval}",
                "behavior": "Tab 自动轮播，鼠标移入停止，移出恢复"
            }
        ],
        "visual_configs": {
            "common": {
                "sortField": { "type": "string", "default": "" },
                "labelFont": { "component": "VisualTextStyle" }
            },
            "tabSettings": {
