  "capabilities": {
    "data_formats": [
      {
        "format": "多系列横向条形（2维度+3指标）",
        "example": "[{ dimensionName: '2G', compareType: '小区数(万)', indicatorId: 1, indicatorValue: 15, unit: '万' }, ...]",
        "match_pattern": "data[*].{dimensionName, compareType, indicatorId, indicatorValue}",
        "supports_multi_series": true,
        "multi_series_key": "compareType",
        "fields": [
          { "name": "dimensionName", "type": "String", "required": true, "description": "Y轴类目，会 _.uniq 去重" },
          { "name": "compareType", "type": "String", "required": false, "description": "多系列分组键；存在时按此分组生成 series；data[0] 是否存在此字段决定走多系列还是单系列分支" },
          { "name": "indicatorId", "type": "String", "required": false, "description": "联动ID（点击事件 onClickId 派发来源）" },
          { "name": "indicatorValue", "type": "String(实际number)", "required": true, "description": "Y轴数据值，ECharts 数值" },
          { "name": "indicatorUnit", "type": "String", "required": false, "description": "单位（当前组件未使用此字段，dataModel 已声明但未消费）" }
        ],
        "private_field": {
          "name": "__rawData__",
          "description": "options.ts 注入的原始数据对象；ECharts 不识别但保留在 data 对象上，用于点击事件读取全量字段"
        }
      }
    ],
    "interactions": [
      {
        "type": "drilldown",
        "trigger": "click",
        "config_field": "interactions.defined.configurableEvent.drilldownEvent",
        "sub_fields": ["show", "effect (Modal|Drawer)", "params", "drilldownItemFields", "position", "size", "mask", "closable"],
        "payload_fields": ["id", "name", "value"],
        "known_issue": "dataModel 无 id 字段 → onClickId 派发永远为 undefined（详见 gotchas.md § 4）"
      },
      {
        "type": "modal_or_drawer",
        "trigger": "click",
        "config_field": "interactions.defined.configurableEvent.clickEvent",
        "sub_fields": ["show", "effect (Modal|Drawer)"],
        "payload": "整行 raw data"
      }
    ],
    "visual_configs": {
      "chart": {
        "barMaxWidth": { "type": "number", "default": 16, "description": "图形最大宽度" },
        "customColors": { "type": "boolean", "default": true, "description": "是否使用用户自定义渐变色（必须为 true 才生效，见 gotchas § 6）" },
        "color": { "type": "array", "default": "[{ 渐变: 蓝→青 }, { 渐变: 橙→黄 }]", "description": "渐变填充色数组" },
        "borderRadius": { "type": "object", "default": "{top:0,right:8,bottom:8,left:0}" },
        "showBackground": { "type": "boolean", "default": true },
        "backgroundColor": { "type": "string", "default": "rgba(82, 168, 255, 0.1)" },
        "showBarDecal": { "type": "boolean", "default": false },
        "barDecalSetting": { "type": "object", "description": "图案填充，rotation 是度数（options.ts 内部转弧度）" }
      },
      "label": {
        "show": { "type": "boolean", "default": true },
        "textStyle": { "type": "object", "component": "VisualTextStyle" },
        "colorInherit": { "type": "boolean", "default": true, "description": "标签文字与图形同色" },
        "position": { "type": "string", "default": "outside", "options": ["outside", "top", "left", "right", "bottom", "inside", "insideLeft/Right/Top/Bottom", "insideTopLeft/Right/BottomLeft/Right"] },
        "width": { "type": "number", "default": 200, "description": "标签宽度（仅 outside 位置生效）" },
        "padding": { "type": "array", "default": "[{left:-5,top:-20,right:0,bottom:0}, {left:-5,top:20,right:0,bottom:0}]" }
      },
      "xAxis": {
        "showAxisLine": { "type": "boolean", "default": false },
        "axisLineSetting": { "type": "object" },
        "showAxisLabel": { "type": "boolean", "default": true },
        "axisLabel": { "type": "object", "component": "VisualTextStyle" },
        "max": { "type": "number", "default": 20 }
      },
      "yAxis": {
        "showAxisLine": { "type": "boolean", "default": false },
        "axisLineSetting": { "type": "object" },
        "axisLabel": { "type": "object", "component": "VisualTextStyle" }
      },
      "grid": {
        "show": { "type": "boolean", "default": false },
        "containLabel": { "type": "boolean", "default": false },
        "left/right/top/bottom": { "type": "string", "default": "{left:'30',top:'0',right:'60',bottom:'0'}" }
      },
      "legend": {
        "show": { "type": "boolean", "default": true },
        "type": { "type": "string", "default": "plain", "options": ["plain", "scroll"] },
        "icon": { "type": "string", "default": "rect", "options": ["circle", "rect", "roundRect", "triangle", "diamond", "pin", "arrow", "none"] },
        "orient": { "type": "string", "default": "horizontal" },
        "textStyle": { "type": "object", "component": "VisualTextStyle" }
      },
      "tooltip": {
        "show": { "type": "boolean", "default": true },
        "backgroundColor": { "type": "string" },
        "borderColor": { "type": "string" },
        "borderWidth": { "type": "number" },
        "textStyle": { "type": "object", "component": "VisualTextStyle" }
      }
    },
    "default_values": {
      "config.title": "metaInfo.title（多系列条形图(echarts)）",
      "config.width": 498,
      "config.height": 401,
      "config.chart.barMaxWidth": 16,
      "config.chart.customColors": true,
      "config.chart.showBackground": true,
      "config.chart.backgroundColor": "rgba(82, 168, 255, 0.1)",
      "config.chart.borderRadius": "{top:0,right:8,bottom:8,left:0}",
      "config.legend.show": true,
      "config.label.show": true,
      "config.label.colorInherit": true,
      "config.label.position": "outside",
      "config.grid.show": false,
      "config.tooltip.show": true,
      "config.xAxis.max": 20
    }
  },
